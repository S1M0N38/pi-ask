{
  "format_on_save": "on",
  "ensure_final_newline_on_save": true,
  "remove_trailing_whitespace_on_save": true,
  "languages": {
    "TypeScript": {
      "formatter": {
        "external": {
          "command": "pnpm",
          "arguments": [
            "exec",
            "biome",
            "format",
            "--stdin-file-path",
            "{buffer_path}"
          ]
        }
      },
      "hard_tabs": true
    },
    "JSON": {
      "formatter": {
        "external": {
          "command": "pnpm",
          "arguments": [
            "exec",
            "biome",
            "format",
            "--stdin-file-path",
            "{buffer_path}"
          ]
        }
      }
    },
    "JSONC": {
      "formatter": {
        "external": {
          "command": "pnpm",
          "arguments": [
            "exec",
            "biome",
            "format",
            "--stdin-file-path",
            "{buffer_path}"
          ]
        }
      }
    }
  }
}

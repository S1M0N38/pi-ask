{
	"dependencies": {
		"@mariozechner/pi-coding-agent": "0.67.3",
		"@mariozechner/pi-tui": "0.67.3",
		"@sinclair/typebox": "0.34.49"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@types/node": "25.6.0",
		"typescript": "6.0.2"
	},
	"name": "pi-ask",
	"scripts": {
		"test": "node --test tests/*.test.ts",

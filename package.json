	"type": "module",
	"private": true,
	"packageManager": "pnpm@10.33.0",
	"pnpm": {
		"overrides": {
			"@mariozechner/pi-agent-core": "0.67.3",
			"@mariozechner/pi-ai": "0.67.3",
			"@mariozechner/pi-tui": "0.67.3",
